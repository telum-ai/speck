{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_speck_managed": {
    "version": "7.8.0",
    "blocks": [
      "hooks.Stop",
      "hooks.SessionStart",
      "hooks.PostToolUse"
    ]
  },
  "alwaysThinkingEnabled": true,
  "teammateMode": "auto",
  "outputStyle": "Default",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(node *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat specs/projects/*/project-state.md 2>/dev/null || echo 'No active project-state.md found. Run /speck or /recheck to initialize project state.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/after-file-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-gate.sh"
          }
        ]
      }
    ]
  }
}
