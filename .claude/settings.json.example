{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "teammateMode": "auto",
  "outputStyle": "Default",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(node *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat specs/projects/*/project-state.md 2>/dev/null || echo 'No active project-state.md found. Run /speck or /recheck to initialize project state.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/after-file-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Verify task completion and decision logging state before exit. Guidelines:\n1. Under Speck v7, `tasks.md` is strictly a STORY-LEVEL artifact. NEVER create or require `tasks.md` at the project level or workspace root.\n2. If you are actively working inside a story directory (`specs/projects/*/epics/E###-*/stories/S###-*/`), verify that story's `tasks.md` status matches the completion state in its YAML frontmatter.\n3. If you are working at the project level, check for `project-punch-list.md` (or `sprint-log.md` if on Sprint level) rather than `tasks.md`.\n4. If any critical phase decisions were locked during this session, verify they are captured in `project-decisions-log.md`.\n\nIf everything aligns, return {\"ok\": true}. Otherwise, return {\"ok\": false, \"reason\": \"List what remains before exiting\"}."
          }
        ]
      }
    ]
  }
}
